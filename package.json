{
  "name": "admission-followup-crm",
  "version": "1.1.1",
  "private": true,
  "main": "main.js",
  "scripts": {
    "start": "node server.js",
    "electron": "electron .",
    "build": "electron-builder --win --x64"
  },
  "build": {
    "appId": "com.admissioncrm.app",
    "productName": "Admission CRM",
    "directories": {
      "output": "D:\\staff automation\\CRM-Build"
    },
    "files": [
      "main.js",
      "preload.js",
      "server.js",
      "index.html",
      "package.json",
      "node_modules/**/*",
      "!node_modules/.cache/**",
      "!CRM-Build/**"
    ],
    "publish": {
      "provider": "github",
      "owner": "sakthi1993v-glitch",
      "repo": "admission-crm"
    },
    "extraResources": [],
    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "include": "installer.nsh"
    }
  },
  "devDependencies": {
    "@flydotio/dockerfile": "^0.7.10",
    "electron": "^42.4.1",
    "electron-builder": "^26.15.3"
  },
  "dependencies": {
    "electron-updater": "^6.8.9"
  }
}
